{
  "permissions": {
    "allow": [
      "Bash(cargo insta:*)",
      "Bash(cargo clippy:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(just:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo run:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:typescript-eslint.io)",
      "WebFetch(domain:eslint.org)"
    ],
    "deny": [
      "Bash(cargo biome-cli-dev:*)",
      "Bash(cargo biome-cli:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/clippy-on-edit.sh",
            "timeout": 60,
            "statusMessage": "Running clippy..."
          }
        ]
      }
    ]
  }
}
