# `/src/index.ts`

## Source

```ts
export class Box {
	value: number;

	read() {
		const arrow = () => {
			const arrowValue = this.value;
			return arrowValue;
		};

		function nested() {
			const plainValue = this.value;
			return plainValue;
		}

		return arrow();
	}
}

export class Solo {
	read() {
		const noParent = super.value;
		return noParent;
	}
}
```

