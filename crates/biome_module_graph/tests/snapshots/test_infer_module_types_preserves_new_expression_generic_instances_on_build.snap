# `/src/index.ts`

## Source

```ts
export class Box<T> {
	value: T;

	constructor(value: T) {
		this.value = value;
	}
}

export const explicit = new Box<string>("value");
export const explicitValue = explicit.value;

export const inferred = new Box(1);
export const inferredValue = inferred.value;
```

