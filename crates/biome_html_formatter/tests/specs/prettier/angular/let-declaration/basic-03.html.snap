# Input

```html
@let     topLevel    =   value;

@if (condition) {
  @let         nested    =   value;
}

<div *ngIf="condition">
  @let    nestedNgIf    =     value;
</div>

{{topLevel}}

{{nested}}

{{nestedNgIf}}

```


# Prettier differences

```diff
--- Prettier
+++ Biome
@@ -1,15 +1,9 @@
-@let topLevel = value;
+@let topLevel = value; @if (condition) { @let nested = value; }
 
-@if (condition) {
-  @let nested = value;
-}
+<div *ngIf="condition">@let nestedNgIf = value;</div>
 
-<div *ngIf="condition">
-  @let nestedNgIf = value;
-</div>
+{{topLevel}}
 
-{{ topLevel }}
+{{nested}}
 
-{{ nested }}
-
-{{ nestedNgIf }}
+{{nestedNgIf}}
```

# Output

```html
@let topLevel = value; @if (condition) { @let nested = value; }

<div *ngIf="condition">@let nestedNgIf = value;</div>

{{topLevel}}

{{nested}}

{{nestedNgIf}}
```

