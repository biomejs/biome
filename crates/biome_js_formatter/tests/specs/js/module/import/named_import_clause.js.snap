# Input

```js
import {} from /* comment*/ 'foo'
import {} from // comment
'foo'

import {a} from /* comment */'foo'
import {a} from // comment
'foo'
```


# Formatted

```js
import {} from /* comment*/ "foo";
import {} from // comment
"foo";

import { a } from /* comment */ "foo";
import {
	a, // comment
} from "foo";

```
