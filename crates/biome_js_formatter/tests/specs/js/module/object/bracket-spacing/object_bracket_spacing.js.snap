# Input

```js
let a = {
	...spread,

	foo() {
	},

	*foo() {
	},
	...spread,
}

const x = { apple: "banna"};

const y = {
	apple: "banana",
};

({a, b, c} = {a: 'apple', b: 'banana', c: 'coconut'});

({
	a, b, c
} = {a: 'apple', b: 'banana', c: 'coconut' });

```


# Options

```json
{
  "$schema": "../../../../../../../../packages/@biomejs/biome/configuration_schema.json",
  "javascript": {
    "formatter": {
      "bracketSpacing": false
    }
  }
}
```

# Formatted

```js
let a = {
	...spread,

	foo() {},

	*foo() {},
	...spread,
};

const x = {apple: "banna"};

const y = {
	apple: "banana",
};

({a, b, c} = {a: "apple", b: "banana", c: "coconut"});

({a, b, c} = {a: "apple", b: "banana", c: "coconut"});

```
