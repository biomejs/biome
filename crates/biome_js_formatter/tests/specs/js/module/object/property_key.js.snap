# Input

```js
const foo = {
  "foo-bar": true,
  "bar": {
    "lorem_ispsum": {
      "lorem-ipsum": true
    },
  },
	// https://github.com/biomejs/biome/issues/7261
	"実用文・会話文": "長文読解",
	"実用文･会話文": "長文読解",
};

```


# Formatted

```js
const foo = {
	"foo-bar": true,
	bar: {
		lorem_ispsum: {
			"lorem-ipsum": true,
		},
	},
	// https://github.com/biomejs/biome/issues/7261
	"実用文・会話文": "長文読解",
	"実用文･会話文": "長文読解",
};

```
