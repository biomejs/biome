# Input

```yml
[
"double
 quoted", 'single
           quoted',
plain
 text, [ nested ],
single: pair,
]

```


# Prettier differences

```diff
--- Prettier
+++ Biome
@@ -1,10 +1,10 @@
 [
   "double
-  quoted",
-  "single
-  quoted",
+ quoted",
+  'single
+           quoted',
   plain
-  text,
+ text,
   [nested],
   single: pair,
 ]
```

# Output

```yml
[
  "double
 quoted",
  'single
           quoted',
  plain
 text,
  [nested],
  single: pair,
]
```
