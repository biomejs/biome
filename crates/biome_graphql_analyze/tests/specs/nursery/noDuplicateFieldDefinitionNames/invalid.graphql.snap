# Input
```graphql
# should generate diagnostics
type SomeObject {
	foo: String
	bar: String
	foo: String
}

interface SomeInterface {
	foo: String
	bar: String
	foo: String
}

input SomeInputObject {
	foo: String
	bar: String
	foo: String
}

extend type SomeObject {
	foo: String
	bar: String
	foo: String
}

extend interface SomeInterface {
	foo: String
	bar: String
	foo: String
}

extend input SomeInputObject {
	foo: String
	bar: String
	foo: String
}

```

