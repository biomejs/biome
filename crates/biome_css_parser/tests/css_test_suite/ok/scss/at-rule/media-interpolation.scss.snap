source: crates/biome_css_parser/tests/spec_test.rs
expression: snapshot
---

## Input

```css
@media (#{$feature}) {
  .box {
    color: red;
  }
}

@media (#{$feature}: #{$value}) {
  .box {
    color: red;
  }
}

@media (#{$min} <= width <= #{$max}) {
  .box {
    color: red;
  }
}

@media (#{$min} <= width) {
  .box {
    color: red;
  }
}

@media (min-width: #{$value}px) {
  .box {
    color: red;
  }
}

@media (#{$min}px <= width) {
  .box {
    color: red;
  }
}

@media (#{$feature}-suffix: 1px) {
  .box {
    color: red;
  }
}

@media #{$query} {
  .box {
    color: red;
  }
}

@media #{$query}, screen {
  .box {
    color: red;
  }
}

@container (#{$feature}: #{$value}) {
  .box {
    color: red;
  }
}

@container (min-width: #{$value}px) {
  .box {
    color: red;
  }
}

```


