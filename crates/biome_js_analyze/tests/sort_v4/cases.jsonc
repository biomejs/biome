[
	// ─── static utilities ──────────────────────────────────────────
	// STATIC_UTILITIES exact-match keywords. Sorted by property_idx,
	// then property_count desc, then name.

	"flex block absolute",
	"static visible flex",                         // already sorted
	"sr-only block flex absolute relative",        // sr-only multi-prop floats up
	"pointer-events-none collapse static visible", // visibility bucket ordered by name
	"flex",                                        // single-token passthrough

	// distinct static utilities inside one property bucket order by
	// name, the way Tailwind emits them — not by utility registration
	// order. Expected order cross-checked against
	// prettier-plugin-tailwindcss 0.8.0.
	"inline flex block hidden grid table contents", // display bucket, name order
	"visible collapse invisible",                   // visibility bucket, name order
	"sticky static relative fixed absolute",        // position bucket, name order

	// ─── functional + named value ──────────────────────────────────
	// Named (theme namespace), NamedKeyword (hardcoded keyword pool),
	// NamedTyped (Number / Percentage / Ratio predicates).

	"bg-red-500 flex p-4",   // ThemeNamespace::Color
	"p-4 m-2 flex",          // NamedTyped(Number)
	"text-lg bg-red-500 p-4",
	"p-4 p-2",               // same basename, ordered by value (p-2 first)
	"origin-top flex p-4",   // NamedKeyword pool
	"flex-1 flex p-4",       // STATIC `flex` wins over functional `flex` basename

	// font basename — Named(Font) for `--font-*` theme keys,
	// Named(FontWeight) for `--font-weight-*` theme keys.
	"font-bold flex p-4",
	"font-serif font-bold flex",
	"font-medium font-sans p-4",

	// w basename — Named(Spacing) for `--spacing-*` keys,
	// NamedTyped(Number) for bare integers, NamedTyped(Ratio) for fractions.
	"w-10 flex p-4",         // NamedTyped(Number)
	"w-1/2 flex p-4",        // NamedTyped(Ratio)
	"w-full flex p-4",       // `full` is no `--spacing-*` key in the default theme → Unknown
	"w-screen w-10 w-full",  // full/screen aren't --spacing-* keys → Unknown floats front

	// aspect basename — NamedKeyword pool (auto/square),
	// Named(Aspect) (theme keys like `video`), NamedTyped(Ratio).
	"aspect-square flex",    // NamedKeyword
	"aspect-video flex",     // Named(Aspect)
	"aspect-9/16 flex",      // NamedTyped(Ratio)

	// ─── negative-prefixed functional utilities ────────────────────
	// Parser splits `-` off; classify routes through `entry.negative`
	// to pick the correct branch slot, and the sign joins the name so
	// negatives group before positives inside a bucket (`-` precedes
	// every letter in code-point order).

	"p-4 flex -mt-2",            // SameBranches: -mt reuses mt's branches
	"flex mt-3 -mt-2",           // negative + positive of same basename, sign orders first
	"flex -mt-2 -inset-2",       // two negatives in distinct property buckets
	"flex -bg-red-500 p-4",      // -bg has no negative entry → Unknown → floats to front
	"p-4 flex -z-auto",          // -z drops NamedKeyword(auto) → resolve fails → Unknown
	"p-4 flex -z-10",            // Distinct: -z keeps NamedTyped(Number), routes to z-index

	// negative static utilities. The parser strips the leading `-` and
	// hands us a TwStaticCandidate; classify keeps the entry only when
	// Tailwind registers a negative form (`has_negative`), falling back
	// to Unknown otherwise.
	"flex p-4 -flex",            // -flex: has_negative is false → Unknown

	// ─── unknown classes ───────────────────────────────────────────
	// Tokens that resolve to no branch float to the front and keep
	// their relative input order (stable sort).

	"p-4 foo flex",
	"baz p-4 foo flex bar",
	"bg-rainbow flex bg-red-500", // basename matches but value resolves to nothing → unknown
	"foo bar baz",                // all unknown — output unchanged
	"flex p-",                    // empty value after `-` → unknown
	"myCustom flex p-4",

	// ─── new value-kind dispatch (post-#10332) ─────────────────────
	// TwNumberValue → NamedTyped(Number); TwPercentageValue →
	// NamedTyped(Percentage); a numeric modifier on a numeric value
	// is treated as a fraction when the entry has a Ratio branch.

	"from-50% flex",              // TwPercentageValue → gradient-stop
	"to-100% via-25% from-50%",   // three gradient stops, stable order within bucket
	"flex w-1/2 w-1/3",           // two ratios share the same w branch, ordered by value text
	"flex bg-red-500/50",         // color modifier — base named color sort key
	"flex text-lg/8",             // line-height modifier — base named text-size sort key
	"flex w-1/foo",               // non-fraction modifier — base number sort key

	// ─── sort_class_list edge cases ────────────────────────────────

	"p-[10px] flex some-unknown",
	"flex [color:red]",
	"flex [--my-var:1]",
	"flex [color:red]/50",
	"bg-[50%] bg-[url('/a.png')] bg-[cover] bg-[#fff]",
	"border-[#f00] border-[2px]",
	"text-[#fff] text-[larger] text-[20px]",
	"bg-[#fff] bg-[COVER] border-[THIN] text-[LARGER] flex",
	"ring-[4px] p-[calc(100%-1rem)] bg-[cover] shadow-[#000] [mask-type:luminance] text-[20px] from-[20%] bg-[url('/hero.png')] border-[2px] flex",

	// ─── arbitrary value modifiers ─────────────────────────────────
	// Modifiers ride along in the candidate name; the base utility and
	// arbitrary value still determine the property bucket, which decides
	// each of these cases.

	"ring-[#000]/50 text-[20px]/8 border-[#f00]/50 flex bg-[#fff]/50",
	"text-[#fff]/50 text-[20px]/8 flex",
	"flex [mask-type:luminance]/50 [color:red]/50",

	// ─── gradients ──────────────────────────────────────────────────
	// from/via/to are registered in order; sort must preserve that
	// bucket order when interleaved with other utilities or shuffled
	// across colors and percentages.

	"to-purple-500 from-blue-500 via-pink-500",                   // colors only, scrambled
	"to-100% via-pink-500 from-blue-500 from-25%",                // mixed color + percentage stops
	"bg-red-500 from-blue-500 to-purple-500",                     // bg-color does not interleave with gradient stops
	"p-4 bg-linear-to-r from-blue-500 to-purple-500 m-2",         // linear gradient with surrounding spacing
	"mask-linear-to-75% mask-linear-from-25%",                    // mask gradient stops

	// ─── value ordering within a utility ───────────────────────────
	// Candidates sharing a property bucket order by natural comparison
	// of their name (digit runs compare numerically), which for one
	// basename is the value text, then the modifier. Expected order
	// cross-checked against prettier-plugin-tailwindcss 0.8.0.

	"p-10 p-2 p-4",                     // numeric, not lexicographic
	"p-2.5 p-2 p-10",                   // decimal segments compare piecewise
	"duration-700 duration-75",         // digit runs compare from their start
	"bg-red-500 bg-red-50 bg-red-100",  // scale steps within one color
	"bg-red-500 bg-blue-500",           // colors order by text, not theme order
	"text-lg text-sm text-2xl text-xs", // digit-led values first, then alphabetical
	"w-2/5 w-1/2",                      // fractions by text, not numeric value
	"leading-6 leading-none leading-3", // digits precede letters
	"-m-4 -m-2 m-1",                    // negatives keep their bucket, values still order
	"bg-red-500/50 bg-red-500/25",      // modifier breaks a value tie
	"text-lg/8 text-sm/6",              // value ordering beats the modifier
	"mt-2 mt-[10px]",                   // concrete number before arbitrary value
	"w-[1px] w-4",                      // bracket text compares as written
	"w-[2px] w-[10rem] w-[13px]",       // numeric inside brackets, across units
	"ease-in ease-out ease-in-out",     // keyword-pool values order by text
	"[display:flex] [display:block]",   // arbitrary properties compare their values
	"p-4! p-2",                         // value order dominates the important suffix

	// ─── important suffix ──────────────────────────────────────────
	// `flex!` sorts exactly where `flex` does; an exact-key tie breaks
	// plain-first. Expected order cross-checked against
	// prettier-plugin-tailwindcss 0.8.0.

	"px-2! flex p-4",               // position-neutral: sorts as px-2
	"underline flex!",              // jumps ahead with its utility
	"flex! flex",                   // twin tie: plain first
	"p-4! p-4",                     // twin tie: plain first even from behind
	"w-1/2! flex",                  // ratio value + important
	"bg-red-500! flex p-4",         // theme value + important
	"flex! block",                  // static bucket + important
	"[display:block]! [color:red]", // arbitrary candidate + important
	"mt-4 -mt-2!",                  // negative + important
	"not-a-class! flex",            // unknown base stays front even with `!`

	// ─── real-world strings (shadcn/ui v4, MIT) ─────────────────────
	// Inputs scrambled; output captured by snapshot.
	// Source: github.com/shadcn-ui/ui registry/new-york-v4.

	// Card
	"shadow-sm text-card-foreground border bg-card gap-6 py-6 rounded-xl flex flex-col",

	// Skeleton
	"bg-accent animate-pulse rounded-md",

	// Button primary variant
	"text-primary-foreground bg-primary hover:bg-primary/90",

	// Button default size
	"px-4 has-[>svg]:px-3 h-9 py-2",

	// Button outline variant
	"hover:text-accent-foreground border bg-background shadow-xs hover:bg-accent dark:border-input dark:bg-input/30 dark:hover:bg-input/50",

	// Button base
	"items-center [&_svg]:pointer-events-none inline-flex disabled:opacity-50 gap-2 focus-visible:border-ring justify-center rounded-md text-sm shrink-0 transition-all font-medium outline-none whitespace-nowrap focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 [&_svg]:shrink-0"
]
