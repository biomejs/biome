# Input
```jsx
// should generate diagnostics

import { useMemo } from "react";

function MissingReturn() {
    const value = useMemo(() => {}, []);

    return <div>{value}</div>;
}

function UnusedMemo(props) {
    useMemo(() => props.value, [props.value]);

    return <div>{props.value}</div>;
}

function DynamicDependencies(props) {
    const value = useMemo(
        () => props.text.toUpperCase(),
        props.enabled ? [props.text] : null,
    );

    return <div>{value}</div>;
}

```

# Diagnostics
```
invalidUseMemo.jsx:6:27 lint/nursery/useReactCompiler ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  i This useMemo callback does not return a value.
  
    5 │ function MissingReturn() {
  > 6 │     const value = useMemo(() => {}, []);
      │                           ^^^^^^^^
    7 │ 
    8 │     return <div>{value}</div>;
  
  i useMemo is for computing and caching a value, so its callback must return the value to memoize.
  
  i Return the computed value from the callback, or use useEffect if this code only performs a side effect.
  
  i This rule belongs to the nursery group, which means it is not yet stable and may change in the future. Visit https://biomejs.dev/linter/#nursery for more information.
  

