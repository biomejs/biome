/* should not generate diagnostics */
import { useEffect, useRef } from "react";

function Valid1() {
  useEffect(() => {
    const timeoutId = setTimeout(() => {}, 1000);
    return () => clearTimeout(timeoutId);
  }, []);
}

function Valid2() {
  useEffect(() => {
    const timeoutId = window.setTimeout(() => {}, 1000);
    return () => window.clearTimeout(timeoutId);
  }, []);
}

