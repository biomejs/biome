function Valid10() {
  useEffect(() => {
    let timeoutId: number | null = null;
    if (Math.random() > 0.5) {
      timeoutId = setTimeout(() => {}, 1000);
    }
    return () => {
      timeoutId && clearTimeout(timeoutId);
    };
  }, []);
}

