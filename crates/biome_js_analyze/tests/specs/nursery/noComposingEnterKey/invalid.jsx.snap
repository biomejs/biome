const keyDown = <input onKeyDown={(e) => {
    if (e.key === "Enter") {
        submitForm();
    }
}} />;

const keyDownWhich = <input onKeyDown={(e) => {
    if (e.which === 13) {
        submit();
    }
}} />;

const keyDownCode = <input onKeyDown={(e) => {
    if (e.code === "Enter") {
        submitForm();
    }
}} />;

