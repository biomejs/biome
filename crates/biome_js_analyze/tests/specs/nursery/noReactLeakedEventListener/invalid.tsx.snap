import { useEffect } from "react";

function Invalid1() {
  useEffect(() => {
    window.addEventListener("resize", handleResize);
  }, []);
}

function Invalid2() {
  useEffect(() => {
    const handleResize1 = () => {};
    const handleResize2 = () => {};
    window.addEventListener("resize", handleResize1);
    return () => {
      window.removeEventListener("resize", handleResize2);
    };
  }, []);
}

