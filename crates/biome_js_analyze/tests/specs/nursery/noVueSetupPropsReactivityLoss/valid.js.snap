# Input
```js
/* should not generate diagnostics */

// Normal usage of props
export default {
  setup(props) {
    console.log(props.foo);
    return () => h('div', props.foo)
  }
}

// Safe destructuring using toRefs
export default {
  setup(props) {
    const { foo } = toRefs(props);
    return () => h('div', foo.value)
  }
}

// Safe conversion using toRef
export default {
  setup(props) {
    const foo = toRef(props, 'foo');
    return () => h('div', foo.value)
  }
}

// Destructuring in nested function/callback
export default {
  setup(props) {
    watch(() => {
      const { foo } = props;
      console.log(foo);
    });
    return () => h('div', props.foo)
  }
}

// Destructuring in nested function declaration
export default {
  setup(props) {
    function a() {
      const { foo } = props;
      console.log(foo);
    }
    return () => h('div', props.foo)
  }
}

// Destructuring in returned render function
export default {
  setup(props) {
    return () => {
      const { foo } = props;
      return h('div', foo);
    }
  }
}

// Destructuring other objects (non-props)
export default {
  setup(props) {
    const myObj = { a: 1 };
    const { a } = myObj;
    return () => h('div', props.foo)
  }
}

// Setup function with second parameter context - normal usage should not error
export default {
  setup(props, context) {
    console.log(props.foo);
    context.emit('event');
    return () => h('div', props.foo)
  }
}

// Safe destructuring with reactive API aliases
export default {
  setup(props) {
    const { foo } = vueToRefs(props);
    return () => h('div', foo.value)
  }
}

// Using ref for individual properties
export default {
  setup(props) {
    const foo = ref(props.foo);
    return () => h('div', foo.value)
  }
}

// Using reactive wrapper
export default {
  setup(props) {
    const reactiveProps = reactive(props);
    return () => h('div', reactiveProps.foo)
  }
}

// Non-setup function should be ignored
export default {
  notSetup({ foo }) {
    return () => h('div', foo)
  }
}

// Non-Vue object should be ignored
const regularObject = {
  setup({ foo }) {
    return () => h('div', foo)
  }
}
```
