# Input
```js
// Parameter destructuring
export default {
  setup({ foo }) {
    return () => h('div', foo)
  }
}

// Root scope const destructuring
export default {
  setup(props) {
    const { foo } = props;
    return () => h('div', foo)
  }
}

// Root scope let destructuring
export default {
  setup(props) {
    let { foo } = props;
    return () => h('div', foo)
  }
}

// Root scope var destructuring
export default {
  setup(props) {
    var { foo } = props;
    return () => h('div', foo)
  }
}

// Root scope assignment destructuring
export default {
  setup(props) {
    let foo;
    ({ foo } = props);
    return () => h('div', foo)
  }
}

// Quoted setup property
export default {
  "setup"(props) {
    const { foo } = props;
    return () => h('div', foo)
  }
}

// Computed property name setup (string)
export default {
  ["setup"](props) {
    const { foo } = props;
    return () => h('div', foo)
  }
}

// Props parameter name is not props
export default {
  setup(p) {
    const { foo } = p;
    return () => h('div', foo)
  }
}

// Named export component
export const MyComponent = {
  setup({ foo }) {
    return () => h('div', foo)
  }
}

// defineComponent wrapped component
export default defineComponent({
  setup(props) {
    const { foo } = props;
    return () => h('div', foo)
  }
})

// Setup function with second parameter context - destructuring should still error
export default {
  setup(props, { emit }) {
    const { foo } = props;
    return () => h('div', foo)
  }
}
```
