invalid.js:2:5 lint/suspicious/noNegationInEqualityCheck  FIXABLE  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  i The negation operator ! is evaluated before the equality operator.
  
    1 │ /* should generate diagnostics */
  > 2 │ if (!a === b) {}
      │     ^^^^^^^^
    3 │ if (!a !== b) {}
    4 │ const isInvalid = !foo === bar;
  
  i This is often a mistake as it compares a boolean value with another value.
  
  i If you want to negate the whole equality, use parentheses: !(a === b).
  
  i Safe fix: Exchange the operator to remove the negation.
  
     1  1 │   /* should generate diagnostics */
     2    │ - if·(!a·===·b)·{}
        2 │ + if·(a·!==·b)·{}
     3  3 │   if (!a !== b) {}
     4  4 │   const isInvalid = !foo === bar;
  

