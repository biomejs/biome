# Input
```js
/* should generate diagnostics */
if (!a === b) {}
if (!a !== b) {}
const isInvalid = !foo === bar;
const isNotEqualInvalid = !foo !== bar;
const result = !a === b ? "no" : "yes";
if (!isReady === true) {}
if (!obj.prop === value) {}
if (!(a) === b) {}

```

