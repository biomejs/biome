# Input
```ts
import { type T1, V1 } from "mod";
// Comment
export { type T1, V1 };

import type { T2, T3 } from "mod";
// Comment
export { type T2, type T3 };

// Comment
export { type T4, V2, type T5 } from "mod";

// Comment
export { type T6, type T7 } from "mod";

```

