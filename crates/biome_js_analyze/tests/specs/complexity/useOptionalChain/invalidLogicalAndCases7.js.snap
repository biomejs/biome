// prefix is a call expression
something() && foo && foo.bar;

// prefix with a chain that has a jump
bar && foo && foo.bar.baz;

// prefix with chained calls
bar && foo && foo.bar && foo.bar();

// longer prefix chain
a && b && c && foo && foo.bar;

// the original issue example
bar && foo && foo.length;

```

