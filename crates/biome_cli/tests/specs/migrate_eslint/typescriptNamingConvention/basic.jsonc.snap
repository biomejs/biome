{
	"linter": {
		"rules": {
			"recommended": false,
			"style": {
				"useNamingConvention": {
					"level": "error",
					"options": {
						"strictCase": false,
						"requireAscii": false,
						"conventions": [
							{
								"selector": { "kind": "enumMember" },
								"formats": ["CONSTANT_CASE"]
							},
							{ "selector": { "kind": "interface" }, "match": "(?:I|IO)(.*)" },
							{
								"selector": {
									"kind": "classProperty",
									"modifiers": ["private"]
								},
								"match": "_([^_]*)",
								"formats": ["camelCase"]
							},
							{ "selector": { "kind": "classProperty" }, "match": "([^_]*)" },
							{ "selector": { "kind": "typeProperty" }, "match": "([^_]*)" },
							{
								"selector": { "kind": "objectLiteralProperty" },
								"match": "([^_]*)"
							}
						]
					}
				}
			}
		}
	}
}

