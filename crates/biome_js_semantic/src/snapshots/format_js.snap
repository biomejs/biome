## Source

```
import { foo } from "bar";

const { a, b: renamed } = foo;

let count = 0;

/**
 * Adds two numbers.
 * @param x - first operand
 * @param y - second operand
 */
function add(x, y) {
    return x + y;
}

/** A simple counter. */
class Counter {
    constructor(initial) {
        this.value = initial;
    }
    increment() {
        this.value++;
    }
}

function outer() {
    let local = 1;
    return () => {
        count++;
        return local + count;
    };
}

for (let i = 0; i < 10; i++) {
    console.log(i);
}

try {
    add(a, renamed);
} catch (e) {
    console.log(e);
}

export default outer;
export { add, Counter };
```

