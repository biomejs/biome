```vue
<p v-text="msg" v-show="ok" dir="auto" v-foo:bar.baz id="hello" class="flex"></p>

<div 
  v-slot:default
  v-on:click="doThis"
  v-once
  ref="my-ref"
  :key="item.id"
  v-bind:src="'/path/to/images/' + fileName"
  spellcheck="true"
  v-for="item in items"
  tabindex="-1"
  @scroll.passive="onScroll"
  :is="tabs[currentTab]"
  v-text="msg"
  dir="auto"
  v-model="countModel"
  v-if="awesome"
  :class="{ red: isRed }"
></div>

<!-- with v-bind="object" -->
