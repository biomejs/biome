---
source: crates/biome_formatter_test/src/snapshot_builder.rs
info: scss/map/keys.scss
---

# Input

```scss
$map: (
  'string': 'hello world',
  ('list'): 'hello world',
  ('key': 'value'): 'hello world',
  ('list', 'long long long long long long long long long long long long long list'): 'hello world',
  ('key': 'value','long long long long long long long long long long long long long map': 'value',): 'hello world',
);

// #10000
$map: (
	('my list'): 'hello world',
);

```


# Prettier differences

```diff
--- Prettier
+++ Biome
@@ -1,15 +1,16 @@
 $map: (
   "string": "hello world",
   ("list"): "hello world",
-  ("key": "value"): "hello world",
   (
-    "list",
-    "long long long long long long long long long long long long long list",
+    "key": "value",
   ): "hello world",
   (
+      "list",
+      "long long long long long long long long long long long long long list"
+  ): "hello world",
+  (
     "key": "value",
-    "long long long long long long long long long long long long long map":
-      "value",
+    "long long long long long long long long long long long long long map": "value",
   ): "hello world",
 );
 
```

# Output

```scss
$map: (
  "string": "hello world",
  ("list"): "hello world",
  (
    "key": "value",
  ): "hello world",
  (
      "list",
      "long long long long long long long long long long long long long list"
  ): "hello world",
  (
    "key": "value",
    "long long long long long long long long long long long long long map": "value",
  ): "hello world",
);

// #10000
$map: (
  ("my list"): "hello world",
);
```

# Lines exceeding max width of 80 characters
```
   13:     "long long long long long long long long long long long long long map": "value",
```
