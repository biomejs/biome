# Prettier differences

```diff
--- Prettier
+++ Biome
@@ -1,9 +1,10 @@
 asdasldaskdhjkashdahsdkjahskdjhakjsdkjahsdhkasdhkajsdhakjsdhkajsdhjkahskjdkjahsjkdjkakjsdm,
-asdasldaskdhjkashdahsdkjahskdjhakjsdkjahsdhkasdhkajsdhakjsdhkajsdhjkahskjdkjahsjkdjkakjsdm {
+asdasldaskdhjkashdahsdkjahskdjhakjsdkjahsdhkasdhkajsdhakjsdhkajsdhjkahskjdkjahsjkdjkakjsdm, {
+
 }
 
-.some-class {
-  &.another-class {
-    color: red;
-  }
+.some-class, {
+&.another-class, {
+     color: red;
+ }
 }
```

