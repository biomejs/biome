# Input

```css
@UTILITY  center-flex    {
	display: flex;
	align-items: center;
	justify-content: center;
}

@UTILITY    sr-only {
	position: absolute;
	width: 1px;
	height: 1px;	padding: 0;	margin: -1px;
	overflow: hidden;	clip: rect(0, 0, 0, 0);
	white-space: nowrap;
	border: 0;
}

@UTILITY tab-4{tab-size:4;}

@UTILITY tab-*{tab-size:--value(--tab-size-*);}

@UTILITY px-*{padding-inline:--value(--padding-inline-*);}

@THEME KeepTheme { --KeepVar: RED; --KeepVar-*: RED; --KeepOther: --value(--KeepRef-*); }

@UTILITY KeepUtility { COLOR: RED; background: --value(--KeepRef-*); }

@UTILITY Keep-* { COLOR: RED; }

@VARIANT KeepVariant { &:HOVER { COLOR: RED; } }

@CUSTOM-VARIANT KeepCustomVariant (&:WHERE(.KeepClass));

@CUSTOM-VARIANT KeepMediaVariant (@MEDIA SCReEN AND (MIN-WIDTH: 700PX));

@CUSTOM-VARIANT KeepContainerVariant (@CONTAINER KeepContainer (WIDTH <= 150PX));

@CUSTOM-VARIANT KeepSupportsVariant (@SUPPORTS (COLOR: RED));

@CUSTOM-VARIANT KeepScopeVariant (@SCOPE (A:HOVER) TO (.KeepEnd:FOCUS));

@CUSTOM-VARIANT KeepColorProfileVariant (@COLOR-PROFILE DEVICE-CMYK);

@CUSTOM-VARIANT KeepPropertyVariant (@PROPERTY --Keep-custom-Prop);

@CUSTOM-VARIANT KeepFontFaceVariant (@FONT-FACE);

@CUSTOM-VARIANT KeepFunctionVariant (@FUNCTION --KeepFunc(--KeepParam <COLOR>#: RED) RETURNS <IDENT>+);

.x { @APPLY KeepUtility KeepOther; }

@SOURCE inline("KeepSource");

@SOURCE not "KeepSourcePath";

@SOURCE INLINE("KeepUpperSource");

@SOURCE NOT "KeepUpperSourcePath";

@REFERENCE "KeepRef.css";

@CONFIG "KeepConfig.js";

@PLUGIN "KeepPlugin" { COLOR: RED; }

@SLOT;

```


