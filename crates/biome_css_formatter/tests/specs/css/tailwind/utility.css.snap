# Formatted

```css
@utility center-flex {
	display: flex;
	align-items: center;
	justify-content: center;
}

@utility sr-only {
	position: absolute;
	width: 1px;
	height: 1px;
	padding: 0;
	margin: -1px;
	overflow: hidden;
	clip: rect(0, 0, 0, 0);
	white-space: nowrap;
	border: 0;
}

@utility tab-4 {
	tab-size: 4;
}

@utility tab-* {
	tab-size: --value(--tab-size-*);
}

@utility px-* {
	padding-inline: --value(--padding-inline-*);
}

@theme KeepTheme {
	--KeepVar: RED;
	--KeepVar-*: RED;
	--KeepOther: --value(--KeepRef-*);
}

@utility KeepUtility {
	color: RED;
	background: --value(--KeepRef-*);
}

@utility Keep-* {
	color: RED;
}

@variant KeepVariant {
	&:hover {
		color: RED;
	}
}

@custom-variant KeepCustomVariant (&:where(.KeepClass));

@custom-variant KeepMediaVariant (@media SCReEN AND (min-width: 700px));

@custom-variant KeepContainerVariant (
	@container KeepContainer (width <= 150px)
);

@custom-variant KeepSupportsVariant (@supports (COLOR: RED));

@custom-variant KeepScopeVariant (@scope (A:hover) TO (.KeepEnd:focus));

@custom-variant KeepColorProfileVariant (@color-profile DEVICE-CMYK);

@custom-variant KeepPropertyVariant (@property --Keep-custom-Prop);

@custom-variant KeepFontFaceVariant (@font-face);

@custom-variant KeepFunctionVariant (
	@function --KeepFunc(--KeepParam <COLOR>#: RED) RETURNS <IDENT>+
);

.x {
	@apply KeepUtility KeepOther;
}

@source inline("KeepSource");

@source not "KeepSourcePath";

@source INLINE("KeepUpperSource");

@source NOT "KeepUpperSourcePath";

@reference "KeepRef.css";

@config "KeepConfig.js";

@plugin "KeepPlugin" {
	COLOR: RED;
}

@slot;

```
