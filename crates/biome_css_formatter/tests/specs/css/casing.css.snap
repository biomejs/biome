	}
	@left-bottom {
		color: RED;
	}
	@right-top {
		color: RED;
	}
	@right-middle {
		color: RED;
	}
	@right-bottom {
		color: RED;
	}
}

@page KeepPageNested:FIRST {
	color: RED;
	@media (width > 500px) {
		A:hover {
			color: RED;
		}
	}
	@top-left {
		color: RED;
		@media (width > 500px) {
			color: BLUE;
		}
	}
}

@document URL("HTTPS://KeepHost/Exact"), URL-PREFIX("HTTPS://KeepHost/Doc"), DOMAIN("KeepHost.COM"), MEDIA-DOCUMENT("KeepMedia"), REGEXP("Keep.*") {
	A {
		color: RED;
	}
}

