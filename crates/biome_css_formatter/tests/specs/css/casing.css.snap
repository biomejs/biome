		else: RED;
	);
	outline-color: if(not style(COLOR: RED): BLUE; else: RED);
	border-top-color: if(
		style((COLOR: RED) and (DISPLAY: GRID)): BLUE;
		else: RED;
	);
	box-shadow: if(style(COLOR: RED): KeepValue / KeepOther; else: KeepThird);
	filter: if(style(((COLOR: RED))): KeepValue / KeepOther; else: KeepThird);
}

@import "KeepCase.CSS" LAYER(Keep.Layer) SUPPORTS(COLOR: RED) PRINT;
.case-tokens[DATA-X I] {
	composes: KeepClass FROM global;
	a: ATTR(DATA-X RAW-STRING, Keep);
	b: ATTR(DATA-X NUMBER, Keep);
	c: ATTR(DATA-X TYPE(<COLOR>), Keep);
	color: IF(
		NOT MEDIA(WIDTH>1PX) AND STYLE(COLOR:RED) OR SUPPORTS(DISPLAY:GRID):RED;
		ELSE: BLUE;
	);
}
@value KeepImported AS KeepLocal FROM KeepSource;
@container STYLE(COLOR: RED) {
	A:hover {
		color: RED;
	}
}
@function --KeepCase(--Keep TYPE(<COLOR>): RED) RETURNS TYPE(<COLOR>) {
	result: RED;
}

