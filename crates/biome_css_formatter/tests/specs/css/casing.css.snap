@layer Keep.Layer, KeepOther;

@namespace Keep url("HTTPS://KeepHost/Namespace");

@namespace "HTTPS://KeepHost/DefaultNamespace";

@namespace KeepString "HTTPS://KeepHost/StringNamespace";

@font-face {
	font-family: KeepFont;
	src: URL("x.woff");
	unicode-range: U+ABCD-EFFF, U+FF??;
}

.grid {
	grid-template-columns: [FULL-Start MAIN-End] 1fr [SIDE-Bar];
}

.raw-url {
	background: URL(HTTPS://EXAMPLE.COM/KeepPath.PNG);
}

.url-modifier {
	background: URL("x.png" KeepMod KeepFuncName(KeepArg));
	mask: SRC("x.svg" KeepSrcMod);
}

.function-value {
	color: KeepFuncName(KeepArg);
}

.function-keyword-value {
	color: KeepFuncName(inherit);
	background: Var(--Keep-custom-Prop, initial);
}

.var-empty-fallback {
	color: Var(--Keep-custom-Prop,);
}

.generic-value {
	--Keep-list: KeepOne, KeepTwo;
	font: 12px / 14px KeepFont;
}

.custom-keyword-value {
	--Keep-keyword: initial;
}

.keyword-value {
	color: initial;
	background-color: REVERT-LAYER;
	border-color: DEFAULT;
}

.important-value {
	color: RED !important;
}

@starting-style {
	A:hover {
		color: RED;
	}
}

@view-transition {
	navigation: AUTO;
}

@keyframes KeepFrames {
	from {
		color: RED;
	}
	to {
		color: BLUE;
	}
}

@keyframes KeepTimeline {
	ENTRY 0% {
		color: RED;
	}
	EXIT 100% {
		color: BLUE;
	}
}

@keyframes "KeepFramesString" {
	to {
		color: RED;
	}
}

@keyframes :GLOBAL KeepFrames {
	from {
		color: RED;
	}
}

@keyframes :LOCAL("KeepFrames") {
	to {
		color: BLUE;
	}
}

@counter-style KeepCounter {
	system: cyclic;
	symbols: "x";
	suffix: " ";
}

@color-profile DEVICE-CMYK {
	src: URL("x");
}

@color-profile KeepProfile {
}

@property --Keep-custom-Prop {
	syntax: "<color>";
	inherits: false;
	initial-value: RED;
}

@font-feature-values KeepFont Family, "Keep Font" {
	@stylistic {
		keepfeaturename: 1;
	}
	@historical-forms {
		keephist: 1;
	}
	@styleset {
		keepset: 1;
	}
	@character-variant {
		keepchar: 1;
	}
	@swash {
		keepswash: 1;
	}
	@ornaments {
		keeporn: 1;
	}
	@annotation {
		keepanno: 1;
	}
}

@font-palette-values --KeepPalette {
	font-family: KeepFont;
}

@position-try --KeepPosition {
	color: RED;
}

@function --KeepFunc(--KeepParam type(<COLOR>): RED) RETURNS type(<COLOR>) {
	result: RED;
}

@function --KeepSyntax(--KeepParam <COLOR>#: RED) RETURNS <IDENT>+ {
	result: RED;
}

@page KeepPage:FIRST {
	color: RED;
	@top-left-corner {
		color: RED;
	}
	@top-left {
		color: RED;
	}
	@top-center {
		color: RED;
