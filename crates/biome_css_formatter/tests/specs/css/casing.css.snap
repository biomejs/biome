```css
/*
 * Role-based casing:
 * - CSS-owned names such as declaration names, pseudo names, and query feature
 *   names are normalized to lowercase.
 * - Document-owned and author-owned names such as type and universal selectors,
 *   classes, ids, attributes, custom properties, custom property values, custom
 *   selector pseudo identifiers, and plain value function names preserve casing.
 */

DIV {
	color: BLUE;
}

DIV.classNames#AND_Ids.ArePreserved {
}

[attr="IdentifierValuesPreserveWhenStringified"] {
}

@media NoT SCReEN AND (color), PRINT AND (color) {
}

DIV {
	--Preserved-Casing: BLUE;
	color: VAR(--Preserved-Casing);
}

@font-palette-values --AnyCASInG-works {
}

/*
 * The only exception (at least that I've found so far in the spec), is @page
 * using a _regular_ identifier for the page name, but where that identifier is
 * considered case-sensitive. Biome uses a CssCustomIdentifier here instead to
 * automatically preserve casing rather than creating a special exception.
 */
@page ThisIsPreserved:FIRST {
}

*|*.KeepUniversal,
|*.KeepDefaultUniversal,
HTML#KeepId.KeepClass,
KeepNs|A.KeepClass,
[KeepNs|viewBox],
svg[viewBox][data-kind="KeepAttrValue" I],
svg[data-mode="KeepAttrValue" S],
a:hover::first-letter,
:--KeepCustom,
:not(:nth-child(2n + 1)),
A:nth-child(2n + 1 OF .KeepClass:hover),
html:active-view-transition-type(KeepBack, KeepForward),
A:dir(RTL):lang(EN):state(KeepState),
:is(.KeepClass:hover, A:focus),
:where(.KeepOther:active),
:host(.KeepHost:hover),
:host-context(.KeepContext:focus),
:-webkit-any(A:hover, .KeepAny:focus),
section:has(> .KeepClass:hover, + A:focus, ~ A:active)::slotted(
	.KeepSlot:active
),
button::part(KeepPart KeepOtherPart),
a::cue(.KeepClass:hover),
video::cue-region(#KeepId > .KeepClass:focus),
A::view-transition-group(KeepView),
a::highlight(KeepHighlight) {
	color: #aabbcc;
	-webkit-user-select: none;
	--Keep-custom-Prop: KeepValue;
	background: Var(--Keep-custom-Prop);
}

A:nth-child(ODD),
B:nth-last-child(EVEN) {
	color: RED;
}

.Nested {
	& .KeepChild:hover {
		color: RED;
	}
