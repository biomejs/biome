# Input

```scss
$map:(('key':'value','key': 'value' ,'key':'value','key' :'value','key':'value',):('key':'value',),('list','list' ,'list','list','list','list','list','list','list','list'):('list'),('list','long long long long long long long long long long long long long list'):'hello world',);

$nested:(key:(nested-key:nested-value,other-key:other-value,),);

```


# Formatted

```scss
$map: (
	(
		"key": "value",
		"key": "value",
		"key": "value",
		"key": "value",
		"key": "value",
	): (
			"key": "value",
		),
	(
		"list",
		"list",
		"list",
		"list",
		"list",
		"list",
		"list",
		"list",
		"list",
		"list",
	): (
			"list",
		),
	(
		"list",
		"long long long long long long long long long long long long long list",
	): "hello world",
);

$nested: (
	key: (
		nested-key: nested-value,
		other-key: other-value,
	),
);

```
