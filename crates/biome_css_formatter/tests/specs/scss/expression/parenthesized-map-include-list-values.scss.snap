source: crates/biome_formatter_test/src/snapshot_builder.rs
info: scss/expression/parenthesized-map-include-list-values.scss
---

# Input

```scss
@include container($foo:2*($bar));
@include container($foo:2*($bar+$baz));
@include container($foo:($bar,$baz));
@include container($foo:($bar+$baz,$qux*2));

$map:(
key:(value),
other-key:(key:other-other-value),
);

$key-values:(
("key":"value","key":"value","key":"value","key":"value","key":"value"):("list"),
("list","list","list","list","list","list","list","list","list","list"):("list"),
);

```


# Formatted

```scss
@include container($foo: 2 * ($bar));
@include container($foo: 2 * ($bar + $baz));
@include container(
	$foo: (
		$bar,
		$baz,
	)
);
@include container(
	$foo: (
		$bar + $baz,
		$qux * 2,
	)
);

$map: (
	key: (value),
	other-key: (
		key: other-other-value,
	),
);

$key-values: (
	(
		"key": "value",
		"key": "value",
		"key": "value",
		"key": "value",
		"key": "value",
	): ("list"),
	(
		"list",
		"list",
		"list",
		"list",
		"list",
		"list",
		"list",
		"list",
		"list",
		"list",
	): ("list"),
);

```
